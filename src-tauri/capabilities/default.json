{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main", "desktop-oauth-google", "desktop-oauth-github"],
    "remote": {
        "urls": [
            "http://localhost:3000",
            "http://localhost:3001",
            "http://localhost:3002",
            "http://localhost:3003",
            "http://localhost:3004",
            "http://localhost:3005",
            "http://127.0.0.1:3000",
            "http://127.0.0.1:3001",
            "http://127.0.0.1:3002",
            "http://127.0.0.1:3003",
            "http://127.0.0.1:3004",
            "http://127.0.0.1:3005"
        ]
    },
    "permissions": [
        "core:default",
        "core:webview:allow-create-webview-window",
        "core:window:allow-close",
        "core:window:allow-hide",
        "opener:default",
        {
            "identifier": "opener:allow-open-path",
            "allow": [
                {
                    "path": "$HOME/.cache/huggingface/lerobot/ai_models"
                },
                {
                    "path": "$HOME/Desktop/Projects/Vulcan/sourccey-desktop/modules/lerobot-vulcan"
                },
                {
                    "path": "$HOME/Desktop/Projects/Vulcan/sourccey-desktop/modules"
                },
                {
                    "path": "$APPDATA/logs"
                },
                {
                    "path": "$APPLOCALDATA/logs"
                },
                {
                    "path": "$APPDATA"
                },
                {
                    "path": "$APPLOCALDATA"
                }
            ]
        },
        "dialog:default",
        "dialog:allow-message",
        "dialog:allow-open",
        "fs:default",
        "fs:allow-read",
        "fs:allow-write",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-read-dir",
        "fs:allow-copy-file",
        "fs:allow-create",
        "fs:allow-remove",
        "fs:allow-rename",
        "shell:allow-spawn",
        "shell:allow-kill",
        "shell:default",
        "process:default",
        "process:allow-exit"
    ]
}
