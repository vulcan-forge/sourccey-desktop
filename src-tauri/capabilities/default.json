{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "remote": {
        "urls": ["http://localhost:3000", "http://127.0.0.1:3000"]
    },
    "permissions": [
        "core:default",
        "opener:default",
        {
            "identifier": "opener:allow-open-path",
            "allow": [
                {
                    "path": "$HOME/.cache/huggingface/lerobot/ai_models"
                },
                {
                    "path": "$HOME/Desktop/Projects/Vulcan/sourccey-desktop/modules/lerobot-vulcan"
                },
                {
                    "path": "$HOME/Desktop/Projects/Vulcan/sourccey-desktop/modules"
                },
                {
                    "path": "$APPDATA/logs"
                },
                {
                    "path": "$APPLOCALDATA/logs"
                },
                {
                    "path": "$APPDATA"
                },
                {
                    "path": "$APPLOCALDATA"
                }
            ]
        },
        "dialog:default",
        "dialog:allow-message",
        "dialog:allow-open",
        "fs:default",
        "fs:allow-read",
        "fs:allow-write",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-read-dir",
        "fs:allow-copy-file",
        "fs:allow-create",
        "fs:allow-remove",
        "fs:allow-rename",
        "process:default",
        "process:allow-exit"
    ]
}
