# Frontend/public build-time config
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_GRAPHQL_API_URL=https://localhost:5001/v1/graphql/
NEXT_PUBLIC_REST_API_URL=https://localhost:5001/api/v1
NEXT_PUBLIC_AUTH_GOOGLE_URL=https://localhost:5001/api/v1/auth/google?redirect_uri={redirect_uri}
NEXT_PUBLIC_AUTH_GITHUB_URL=https://localhost:5001/api/v1/auth/github?redirect_uri={redirect_uri}
NEXT_PUBLIC_ACCOUNT_SUMMARY_URL=https://localhost:5001/api/v1/account/summary
NEXT_PUBLIC_GOOGLE_V3_RECAPTCHA_SITE_KEY=

# Local dev only (self-signed certs)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Build-time only (required for signed updater artifacts)
TAURI_SIGNING_PUBLIC_KEY=
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=